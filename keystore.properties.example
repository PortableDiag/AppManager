# Copy to `keystore.properties` and fill in your own values to build a signed release.
# Without it, `assembleRelease` is unsigned and `assembleDebug` still works.
#   keytool -genkeypair -v -keystore appmanager-release.jks -alias appmanager -keyalg RSA -keysize 2048 -validity 10000
storeFile=appmanager-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=appmanager
keyPassword=YOUR_KEY_PASSWORD
