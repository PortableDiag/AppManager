    <!-- Settings -->
    <string name="settings_repo_title">App sources</string>
    <string name="settings_repo_hint">One URL per line</string>
    <string name="settings_repo_summary">One URL per line. Fastest: paste a GitHub repo page (github.com/you/app) — the latest release APK is found automatically. A URL ending in .apk is a direct APK for one app; any other URL is treated as a repo/index JSON. Apps with no source here fall back to the local folder below.\n\nTip: from a browser you can Share a repo link straight into App Manager, or copy a link and tap + on the main screen.</string>
    <string name="settings_local_title">Local APK folder</string>
    <string name="settings_local_summary">Drop signed APKs in a folder and they\'re scanned automatically. Leave blank to use the app\'s private folder (no permission needed); set any path (e.g. /sdcard/MyApks) to use your own — that needs all-files access.</string>
    <string name="settings_local_hint">Folder path (blank = private folder)</string>
    <string name="settings_local_default">Blank uses: %1$s</string>
    <string name="copy_default_path">Copy default path</string>
    <string name="need_storage_access">Grant all-files access so App Manager can read your APK folder.</string>
    <string name="settings_devs_title">Favorite GitHub devs</string>
    <string name="settings_devs_summary">One GitHub username per line. Every public repo of theirs that ships an APK release is added automatically. Tip: Share or paste a github.com/username link to add one fast.</string>
    <string name="settings_devs_hint">GitHub username (e.g. octocat)</string>
    <string name="dev_added">Following %1$s — finding their apps…</string>
    <string name="dev_exists">Already following %1$s</string>

