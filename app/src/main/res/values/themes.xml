<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AppManager" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorOnPrimary">@color/on_brand</item>
        <item name="colorPrimaryContainer">@color/brand_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:colorBackground">@color/light_bg</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorSurfaceVariant">@color/light_surface_variant</item>
        <item name="colorOnSurface">@color/light_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/light_on_surface_variant</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">?android:colorBackground</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <!-- 90s hacker / terminal: green mono; neon-on-black in dark, green-on-white in light. -->
    <style name="Theme.AppManager.Terminal" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/term_primary</item>
        <item name="colorOnPrimary">@color/term_on_primary</item>
        <item name="colorPrimaryContainer">@color/term_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/term_on_primary_container</item>
        <item name="colorSecondary">@color/term_secondary</item>
        <item name="colorOnSecondary">@color/term_on_primary</item>

        <item name="android:colorBackground">@color/term_bg</item>
        <item name="colorSurface">@color/term_surface</item>
        <item name="colorSurfaceVariant">@color/term_surface_variant</item>
        <item name="colorOnSurface">@color/term_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/term_on_surface_variant</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">?android:colorBackground</item>

        <item name="fontFamily">monospace</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
